// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String?
  googleId      String?   @unique
  avatarUrl     String?
  role          String    @default("admin")
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company?
  counters      Counter?
  templates     Template?
  
  clients       Client[]
  documents     Document[]
}

model Company {
  id                String  @id @default(uuid())
  name              String
  nit               String
  address           String
  phone             String
  email             String
  city              String?
  department        String?
  country           String?
  website           String?
  tagline           String?
  legalRep          String?
  legalRepId        String?
  logoPath          String?
  signPath          String?

  // Payment methods (max 3) — JSON array of { bankName, bankAccountType, bankAccountNum, bankHolder }
  paymentMethods    Json    @default("[]")

  // Tax Config
  ivaRate           Float   @default(19)
  retencionRate     Float   @default(3.5)
  regimenTributario String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String  @unique
}

model Template {
  id            String @id @default(uuid())
  cuentaCobro   String @default("default")
  cotizacion    String @default("default")
  contrato      String @default("default")
  
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String @unique
}

model Counter {
  id            String @id @default(uuid())
  cuentaCobro   Int    @default(0)
  cotizacion    Int    @default(0)
  contrato      Int    @default(0)
  
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String @unique
}

model Client {
  id        String   @id @default(uuid())
  name      String
  nit       String
  address   String
  email     String
  city      String
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
}

model Document {
  id         String   @id @default(uuid())
  type       String   // cuenta-cobro, cotizacion, contrato
  number     String
  title      String
  filePath   String
  clientName String
  total      Float
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
}